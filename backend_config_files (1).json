PORT=3000
NODE_ENV=production

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=/var/www/lost-found/uploads/

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (Optional)
EMAIL_HOST=smtp.your-college.edu
EMAIL_PORT=587
