# Test Suite
# tests/api.test.js

const request = require('supertest');
const app = require('../server');
const { Pool } = require('pg');

// Test database configuration
const testPool = new Pool({
    user: process.env.TEST_DB_USER || 'postgres',
    host: process.env.TEST_DB_HOST || 'localhost',
    database: process.env.TEST_DB_NAME || 'lost_found_test_db',
    password: process.env.TEST_DB_PASSWORD || 'password',
    port: process.env.TEST_DB_PORT || 5432,
});

describe('Lost & Found API', () => {
    let authToken;
    let testItemId;

    beforeAll(async () => {
        // Setup test database
        await testPool.query('DROP TABLE IF EXISTS search_logs CASCADE');
        await testPool.query('DROP TABLE IF EXISTS collection_history CASCADE');
        await testPool.query('DROP TABLE IF EXISTS lost_items CASCADE');
        await testPool.query('DROP TABLE IF EXISTS users CASCADE');
        
        // Run migrations for test database
        // ... (run the same schema creation as in migration)
    });

    afterAll(async () => {
        await testPool.end();
    });

    beforeEach(async () => {
        // Clean up data before each test
        await testPool.query('TRUNCATE users, lost_items, collection_history, search_logs RESTART IDENTITY CASCADE');
        
        // Insert test admin user
        const bcrypt = require('bcryptjs');
        const hashedPassword = await bcrypt.hash('testpass', 10);
        await testPool.query(
            'INSERT INTO users (email, username, password_hash, role) VALUES ($1, $2, $3, $4)',
            ['test@college.edu', 'testadmin', hashedPassword, 'admin']
        );
    });

    describe('Authentication', () => {
        test('POST /api/auth/login - successful login', async () => {
            const response = await request(app)
                .post('/api/auth/login')
                .send({
                    username: 'testadmin',
                    password: 'testpass'
                });

            expect(response.status).toBe(200);
            expect(response.body.message).toBe('Login successful');
            expect(response.body.token).toBeDefined();
            expect(response.body.user.username).toBe('testadmin');
            
            authToken = response.body.token;
        });

        test('POST /api/auth/login - invalid credentials', async () => {
            const response = await request(app)
                .post('/api/auth/login')
                .send({
                    username: 'testadmin',
                    password: 'wrongpass'
                });

            expect(response.status).toBe(401);
            expect(response.body.error).toBe('Invalid credentials');
        });
    });

    describe('Lost Items', () => {
        beforeEach(async () => {
            // Login to get auth token
            const loginResponse = await request(app)
                .post('/api/auth/login')
                .send({
                    username: 'testadmin',
                    password: 'testpass'
                });
            authToken = loginResponse.body.token;
        });

        test('GET /api/lost-items - get all items', async () => {
            const response = await request(app)
                .get('/api/lost-items');

            expect(response.status).toBe(200);
            expect(response.body.items).toBeDefined();
            expect(Array.isArray(response.body.items)).toBe(true);
        });

        test('POST /api/lost-items - add new item', async () => {
            const response = await request(app)
                .post('/api/lost-items')
                .set('Authorization', `Bearer ${authToken}`)
                .send({
                    name: 'Test iPhone',
                    description: 'Black iPhone for testing',
                    category: 'electronics',
                    found_location: 'Library',
                    collect_location: 'Security Office'
                });

            expect(response.status).toBe(201);
            expect(response.body.message).toBe('Lost item added successfully');
            expect(response.body.item.name).toBe('Test iPhone');
            
            testItemId = response.body.item.id;
        });

        test('POST /api/lost-items - validation error', async () => {
            const response = await request(app)
                .post('/api/lost-items')
                .set('Authorization', `Bearer ${authToken}`)
                .send({
                    name: 'Test Item'
                    // Missing required fields
                });

            expect(response.status).toBe(400);
            expect(response.body.error).toContain('Missing required fields');
        });

        test('PUT /api/lost-items/:id - update item', async () => {
            // First create an item
            const createResponse = await request(app)
                .post('/api/lost-items')
                .set('Authorization', `Bearer ${authToken}`)
                .send({
                    name: 'Original Name',
                    description: 'Original description',
                    category: 'electronics',
                    found_location: 'Library',
                    collect_location: 'Security Office'
                });
            
            const itemId = createResponse.body.item.id;

            // Then update it
            const response = await request(app)
                .put(`/api/lost-items/${itemId}`)
                .set('Authorization', `Bearer ${authToken}`)
                .send({
                    name: 'Updated Name',
                    description: 'Updated description'
                });

            expect(response.status).toBe(200);
            expect(response.body.item.name).toBe('Updated Name');
            expect(response.body.item.description).toBe('Updated description');
        });

        test('POST /api/items/:id/collect - mark as collected', async () => {
            // First create an item
            const createResponse = await request(app)
                .post('/api/lost-items')
                .set('Authorization', `Bearer ${authToken}`)
                .send({
                    name: 'Test Item',
                    description: 'Test description',
                    category: 'electronics',
                    found_location: 'Library',
                    collect_location: 'Security Office'
                });
            
            const itemId = createResponse.body.item.id;

            // Mark as collected
            const response = await request(app)
                .post(`/api/items/${itemId}/collect`)
                .set('Authorization', `Bearer ${authToken}`)
                .send({
                    collected_by_name: 'John Doe',
                    collected_by_contact: 'john@college.edu'
                });

            expect(response.status).toBe(200);
            expect(response.body.message).toBe('Item marked as collected successfully');
        });
    });

    describe('Search and Filters', () => {
        beforeEach(async () => {
            const loginResponse = await request(app)
                .post('/api/auth/login')
                .send({
                    username: 'testadmin',
                    password: 'testpass'
                });
            authToken = loginResponse.body.token;

            // Create test items
            await request(app)
                .post('/api/lost-items')
                .set('Authorization', `Bearer ${authToken}`)
                .send({
                    name: 'iPhone 13',
                    description: 'Black phone',
                    category: 'electronics',
                    found_location: 'Library',
                    collect_location: 'Security Office'
                });

            await request(app)
                .post('/api/lost-items')
                .set('Authorization', `Bearer ${authToken}`)
                .send({
                    name: 'Red Backpack',
                    description: 'Nike backpack',
                    category: 'accessories',
                    found_location: 'Cafeteria',
                    collect_location: 'Lost & Found Office'
                });
        });

        test('GET /api/lost-items - search functionality', async () => {
            const response = await request(app)
                .get('/api/lost-items?search=iPhone');

            expect(response.status).toBe(200);
            expect(response.body.items.length).toBe(1);
            expect(response.body.items[0].name).toContain('iPhone');
        });

        test('GET /api/lost-items - category filter', async () => {
            const response = await request(app)
                .get('/api/lost-items?category=electronics');

            expect(response.status).toBe(200);
            expect(response.body.items.length).toBe(1);
            expect(response.body.items[0].category).toBe('electronics');
        });

        test('GET /api/lost-items - location filter', async () => {
            const response = await request(app)
                .get('/api/lost-items?found_location=library');

            expect(response.status).toBe(200);
            expect(response.body.items.length).toBe(1);
            expect(response.body.items[0].found_location).toContain('Library');
        });
    });

    describe('AI Assistant', () => {
        test('POST /api/ai-assistant - natural language query', async () => {
            const response = await request(app)
                .post('/api/ai-assistant')
                .send({
                    query: 'show me phones found in the library'
                });

            expect(response.status).toBe(200);
            expect(response.body.query).toBe('show me phones found in the library');
            expect(response.body.response).toBeDefined();
            expect(response.body.search_params).toBeDefined();
        });

        test('POST /api/ai-assistant - empty query', async () => {
            const response = await request(app)
                .post('/api/ai-assistant')
                .send({
                    query: ''
                });

            expect(response.status).toBe(400);
            expect(response.body.error).toBe('Query is required');
        });
    });

    describe('Statistics', () => {
        test('GET /api/stats - requires authentication', async () => {
            const response = await request(app)
                .get('/api/stats');

            expect(response.status).toBe(401);
            expect(response.body.error).toBe('Access denied. No token provided.');
        });

        test('GET /api/stats - with authentication', async () => {
            const loginResponse = await request(app)
                .post('/api/auth/login')
                .send({
                    username: 'testadmin',
                    password: 'testpass'
                });

            const response = await request(app)
                .get('/api/stats')
                .set('Authorization', `Bearer ${loginResponse.body.token}`);

            expect(response.status).toBe(200);
            expect(response.body.summary).toBeDefined();
            expect(response.body.summary.active_items).toBeDefined();
            expect(response.body.summary.collected_items).toBeDefined();
            expect(response.body.summary.success_rate).toBeDefined();
        });
    });
});

