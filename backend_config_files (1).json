# Production Deployment Script
# deploy.sh

#!/bin/bash

set -e

echo "🚀 Deploying Lost & Found System..."

# Configuration
APP_NAME="lost-found-api"
DB_NAME="lost_found_db"
BACKUP_DIR="/var/backups/lost-found"
LOG_DIR="/var/log/lost-found"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check if running as root
if [[ $EUID -eq 0 ]]; then
   print_error "This script should not be run as root for security reasons"
   exit 1
fi

# Check dependencies
print_status "Checking dependencies..."
command -v node >/dev/null 2>&1 || { print_error "Node.js is required but not installed. Aborting."; exit 1; }
command -v npm >/dev/null 2>&1 || { print_error "npm is required but not installed. Aborting."; exit 1; }
command -v psql >/dev/null 2>&1 || { print_error "PostgreSQL client is required but not installed. Aborting."; exit 1; }
command -v pm2 >/dev/null 2>&1 || { print_error "PM2 is required but not installed. Run: npm install -g pm2"; exit 1; }

# Create necessary directories
print_status "Creating directories..."
sudo mkdir -p $BACKUP_DIR
sudo mkdir -p $LOG_DIR
sudo mkdir -p /var/www/lost-found/uploads
sudo chown -R $USER:$USER /var/www/lost-found

# Database backup
print_status "Creating database backup..."
timestamp=$(date +%Y%m%d_%H%M%S)
sudo -u postgres pg_dump $DB_NAME > $BACKUP_DIR/backup_$timestamp.sql || print_warning "Database backup failed (database might not exist yet)"

# Stop existing application
print_status "Stopping existing application..."
pm2 stop $APP_NAME 2>/dev/null || print_warning "Application not currently running"

# Update application code
print_status "Updating application code..."
cd /var/www/lost-found
git pull origin main || print_error "Failed to pull latest code"

# Install dependencies
print_status "Installing dependencies..."
npm ci --production

# Run database migrations
print_status "Running database migrations..."
node -e "
const { Pool } = require('pg');
const fs = require('fs');
const pool = new Pool({
    user: process.env.DB_USER || 'postgres',
    host: process.env.DB_HOST || 'localhost',
    database: process.env.DB_NAME || '$DB_NAME',
    password: process.env.DB_PASSWORD,
    port: process.env.DB_PORT || 5432,
});

async function migrate() {
    try {
        const migration = fs.readFileSync('./migrations/001_initial_schema.sql', 'utf8');
        await pool.query(migration);
        console.log('Migration completed successfully');
        await pool.end();
    } catch (err) {
        console.error('Migration failed:', err);
        process.exit(1);
    }
}

migrate();
"

# Build application (if applicable)
print_status "Building application..."
npm run build 2>/dev/null || print_warning "No build script found, skipping..."

# Set proper permissions
print_status "Setting permissions..."
sudo chown -R $USER:$USER /var/www/lost-found
chmod -R 755 /var/www/lost-found
chmod -R 755 /var/www/lost-found/uploads

# Start application with PM2
print_status "Starting application..."
NODE_ENV=production pm2 start server.js --name $APP_NAME --log $LOG_DIR/app.log --error $LOG_DIR/error.log --restart-delay=3000

# Configure PM2 to start on boot
pm2 save
pm2 startup | tail -n 1 | sudo bash || print_warning "Failed to configure PM2 startup"

# Setup log rotation
print_status "Setting up log rotation..."
sudo tee /etc/logrotate.d/lost-found > /dev/null <<EOF
$LOG_DIR/*.log {
    daily
    missingok
    rotate 30
    compress
    notifempty
    create 644 $USER $USER
    postrotate
        pm2 reloadLogs
    endscript
}
EOF

# Setup nginx configuration (if nginx is installed)
if command -v nginx >/dev/null 2>&1; then
    print_status "Configuring nginx..."
    sudo tee /etc/nginx/sites-available/lost-found > /dev/null <<EOF
server {
    listen 80;
    server_name your-domain.com;
    
    # Redirect HTTP to HTTPS
    return 301 https://\$server_name\$request_uri;
}

server {
    listen 443 ssl http2;
    server_name your-domain.com;
    
    # SSL configuration (update paths to your certificates)
    ssl_certificate /etc/ssl/certs/your-cert.pem;
    ssl_certificate_key /etc/ssl/private/your-key.pem;
    
    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header X-Content-Type-Options "nosniff" always;
    
    # API proxy
    location /api {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_cache_bypass \$http_upgrade;
    }
    
    # Static file serving
    location /uploads {
        alias /var/www/lost-found/uploads;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
    
    # Frontend (if serving from same server)
    location / {
        root /var/www/lost-found/public;
        try_files \$uri \$uri/ /index.html;
    }
}
EOF

    sudo ln -sf /etc/nginx/sites-available/lost-found /etc/nginx/sites-enabled/
    sudo nginx -t && sudo systemctl reload nginx || print_warning "Nginx configuration failed"
fi

# Health check
print_status "Performing health check..."
sleep 5
curl -f http://localhost:3000/api/health || print_error "Health check failed"

# Final status
print_status "Deployment completed successfully!"
print_status "Application is running on: http://localhost:3000"
print_status "View logs with: pm2 logs $APP_NAME"
print_status "View status with: pm2 status"

echo ""
echo "📋 Post-deployment checklist:"
echo "  ✓ Update SSL certificates if using HTTPS"
echo "  ✓ Configure firewall rules"
echo "  ✓ Set up monitoring and alerting"
echo "  ✓ Configure database backups"
echo "  ✓ Test all API endpoints"
echo "  ✓ Verify file uploads are working"
echo ""

