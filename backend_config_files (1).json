# Database Migration Script
# migrations/001_initial_schema.sql

-- Create database schema for Lost & Found system

-- Enable UUID extension
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- Users table for authentication
CREATE TABLE IF NOT EXISTS users (
    id SERIAL PRIMARY KEY,
    email VARCHAR(255) UNIQUE NOT NULL,
    username VARCHAR(100) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    role VARCHAR(20) DEFAULT 'admin' CHECK (role IN ('admin', 'staff', 'student')),
    is_active BOOLEAN DEFAULT TRUE,
    last_login TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Lost items table
CREATE TABLE IF NOT EXISTS lost_items (
    id SERIAL PRIMARY KEY,
    uuid UUID DEFAULT uuid_generate_v4() UNIQUE,
    name VARCHAR(255) NOT NULL,
    description TEXT,
    category VARCHAR(50) CHECK (category IN ('electronics', 'clothing', 'accessories', 'documents', 'other')),
    found_location VARCHAR(255) NOT NULL,
    collect_location VARCHAR(255) NOT NULL,
    image_url VARCHAR(500),
    status VARCHAR(20) DEFAULT 'active' CHECK (status IN ('active', 'collected', 'archived')),
    upload_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    collected_date TIMESTAMP,
    archived_date TIMESTAMP,
    added_by INTEGER REFERENCES users(id) ON DELETE SET NULL,
    collected_by VARCHAR(255),
    notes TEXT,
    contact_info JSONB, -- For storing contact information
    metadata JSONB, -- For storing additional item metadata
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Collection history for tracking who collected items
CREATE TABLE IF NOT EXISTS collection_history (
    id SERIAL PRIMARY KEY,
    item_id INTEGER REFERENCES lost_items(id) ON DELETE CASCADE,
    collected_by_name VARCHAR(255) NOT NULL,
    collected_by_contact VARCHAR(255),
    collection_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    verification_method VARCHAR(100), -- ID check, phone verification, etc.
    notes TEXT,
    metadata JSONB
);

-- Search logs for AI assistant and analytics
CREATE TABLE IF NOT EXISTS search_logs (
    id SERIAL PRIMARY KEY,
    search_query TEXT NOT NULL,
    results_count INTEGER DEFAULT 0,
    search_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    ip_address VARCHAR(45),
    user_agent TEXT,
    response_time_ms INTEGER,
    metadata JSONB
);

-- Categories lookup table
CREATE TABLE IF NOT EXISTS categories (
    id SERIAL PRIMARY KEY,
    name VARCHAR(50) UNIQUE NOT NULL,
    description TEXT,
    icon VARCHAR(50),
    color VARCHAR(7), -- Hex color code
    is_active BOOLEAN DEFAULT TRUE,
    display_order INTEGER DEFAULT 0
);

-- Locations lookup table  
CREATE TABLE IF NOT EXISTS locations (
    id SERIAL PRIMARY KEY,
    name VARCHAR(255) UNIQUE NOT NULL,
    type VARCHAR(50), -- building, room, outdoor, etc.
    description TEXT,
    is_active BOOLEAN DEFAULT TRUE,
    display_order INTEGER DEFAULT 0
);

-- Create indexes for better performance
CREATE INDEX IF NOT EXISTS idx_lost_items_status ON lost_items(status);
CREATE INDEX IF NOT EXISTS idx_lost_items_category ON lost_items(category);
CREATE INDEX IF NOT EXISTS idx_lost_items_upload_date ON lost_items(upload_date);
CREATE INDEX IF NOT EXISTS idx_lost_items_found_location ON lost_items(found_location);
CREATE INDEX IF NOT EXISTS idx_search_logs_date ON search_logs(search_date);
CREATE INDEX IF NOT EXISTS idx_collection_history_date ON collection_history(collection_date);

-- Full text search indexes
CREATE INDEX IF NOT EXISTS idx_lost_items_search ON lost_items 
USING gin(to_tsvector('english', name || ' ' || COALESCE(description, '')));

-- Insert default data
INSERT INTO categories (name, description, icon, color, display_order) VALUES
('electronics', 'Mobile phones, laptops, chargers, etc.', 'fas fa-mobile-alt', '#1E88E5', 1),
('clothing', 'Jackets, shirts, shoes, accessories', 'fas fa-tshirt', '#26A69A', 2),
('accessories', 'Bags, wallets, jewelry, watches', 'fas fa-backpack', '#FF9800', 3),
('documents', 'ID cards, licenses, certificates', 'fas fa-id-card', '#9C27B0', 4),
('other', 'Items that don\'t fit other categories', 'fas fa-box', '#607D8B', 5)
ON CONFLICT (name) DO NOTHING;

INSERT INTO locations (name, type, description, display_order) VALUES
('Library - Main Floor', 'building', 'Main library building ground floor', 1),
('Library - Study Rooms', 'building', 'Private study rooms in library', 2),
('Cafeteria - Dining Area', 'building', 'Main dining hall seating area', 3),
('Cafeteria - Food Court', 'building', 'Food court and vendor area', 4),
('Computer Lab A', 'room', 'Main computer laboratory', 5),
('Computer Lab B', 'room', 'Secondary computer laboratory', 6),
('Gymnasium - Main Floor', 'building', 'Main gymnasium floor', 7),
('Gymnasium - Locker Rooms', 'building', 'Changing and locker areas', 8),
('Parking Lot - Main', 'outdoor', 'Main campus parking area', 9),
('Parking Lot - Staff', 'outdoor', 'Faculty and staff parking', 10),
('Classroom Building A', 'building', 'Academic building A', 11),
('Classroom Building B', 'building', 'Academic building B', 12),
('Student Center', 'building', 'Student activities center', 13),
('Dormitory - Common Area', 'building', 'Residence hall common spaces', 14),
('Campus Grounds', 'outdoor', 'General campus outdoor areas', 15)
